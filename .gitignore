# ── Python bytecode ────────────────────────────────────────────────────────
**/__pycache__/
**/*.py[cod]
**/*.pyo

# ── Distribution / packaging ────────────────────────────────────────────────
*.egg-info/
dist/
build/
*.egg

# ── Virtual environments ────────────────────────────────────────────────────
.venv/
venv/
env/

# ── Testing & coverage ──────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/

# ── Linting caches ──────────────────────────────────────────────────────────
.ruff_cache/
.mypy_cache/

# ── Environment files (keep .env.example, ignore real .env) ─────────────────
.env

# ── IDE / editor ─────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── Claude Code local settings ───────────────────────────────────────────────
.claude/settings.local.json
