APP_NAME=sunshine-backend
APP_ENV=local

DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_NAME=sunshine
DATABASE_USER=sunshine
DATABASE_PASSWORD=change-me-local-only
DATABASE_URL=postgresql+asyncpg://sunshine:change-me-local-only@postgres:5432/sunshine

POSTGRES_DB=sunshine
POSTGRES_USER=sunshine
POSTGRES_PASSWORD=change-me-local-only

SPECIES_CLASSIFIER_PROVIDER=mock
PLANT_ID_API_KEY=
PLANT_ID_API_URL=
PLANT_ID_TIMEOUT_SECONDS=10

LLM_BACKEND=mock
QWEN_LLM_MODEL=qwen3.6
QWEN_LLM_BASE_URL=http://localhost:8080
QWEN_LLM_TIMEOUT_SECONDS=120
QWEN_LLM_API_KEY=
QWEN_LLM_AUTH_HEADER=Authorization
QWEN_ENDPOINT_REGISTRY_MODE=env
QWEN_ENDPOINT_REGISTRY_FILE=/app/runtime/qwen_endpoint.json

INTERNAL_TOKEN=
